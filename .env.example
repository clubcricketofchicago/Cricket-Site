# ---- Database (Postgres) ----
# App runtime uses DATABASE_URL (Neon POOLED endpoint, "-pooler" host, &pgbouncer=true).
# Migrations/sync use DIRECT_URL (Neon DIRECT endpoint). For a plain local Postgres,
# set both to the same value.
DATABASE_URL="postgresql://ccc:ccc@localhost:5432/ccc"
DIRECT_URL="postgresql://ccc:ccc@localhost:5432/ccc"

# ---- CricClubs core API ----
# Selector is clubId (the association param is ignored by the API).
# clubId 63 = "Midwest Cricket Conference", where Club Cricket of Chicago competes.
CRICCLUBS_BASE_URL="https://core-prod-origin.cricclubs.com/core"
CRICCLUBS_CLUB_ID="63"
CRICCLUBS_ASSOCIATION="mwcc"
# Conference-wide API keys (ask the MWCC admin; also present in the overlays app config).
X_CONSUMER_KEY="<consumer-key>"
X_API_KEY="<api-key>"
# Only needed for the auth-gated endpoints (series details/numbers/rankings); optional.
CRICCLUBS_AUTH_TOKEN=""

# ---- Sync trigger ----
# Shared secret required to call GET /api/sync (Authorization: Bearer <CRON_SECRET>).
CRON_SECRET="change-me"

# ---- Craft CMS (existing; editorial content) ----
NEXT_PUBLIC_CMS_URL="https://cms.ccc.clubcricketofchicago.com/"
